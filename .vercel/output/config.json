{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/posts/new/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/posts/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/posts/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/posts/([^/]+?)/delete/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/posts/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/posts/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/logout/?$",
			"dest": "_render"
		},
		{
			"src": "^/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}