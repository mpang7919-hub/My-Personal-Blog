---
import { siteConfig } from "../lib/site";
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p>{siteConfig.footerText}</p>
    <div class="footer-links">
      {siteConfig.socialLinks.map((link) => <a href={link.href}>{link.label}</a>)}
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    border-top: 1px solid var(--line);
    color: var(--muted);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 2rem;
  }

  .footer-inner p {
    margin: 0;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }
</style>
