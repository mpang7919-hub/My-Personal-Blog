---
const {
  action,
  title,
  submitLabel,
  previewHtml = "",
  values = {},
} = Astro.props as {
  action: string;
  title: string;
  submitLabel: string;
  previewHtml?: string;
  values?: {
    slug?: string;
    title?: string;
    description?: string;
    seoTitle?: string;
    seoDescription?: string;
    content?: string;
    cover?: string | null;
    status?: "draft" | "published";
    featured?: boolean;
    tagNames?: string[];
  };
};

const joinedTags = (values.tagNames ?? []).join(", ");
---

<section class="form-card">
  <div class="form-head">
    <p class="eyebrow">Editor</p>
    <h1>{title}</h1>
  </div>

  <div class="editor-shell">
    <form action={action} method="POST" class="editor-form">
    <label class="full">
      <span>标题</span>
      <input type="text" name="title" value={values.title ?? ""} required />
    </label>

    <div class="two-col">
      <label>
        <span>Slug</span>
        <input type="text" name="slug" value={values.slug ?? ""} placeholder="article-slug" />
      </label>
      <label>
        <span>状态</span>
        <select name="status" value={values.status ?? "draft"}>
          <option value="draft" selected={(values.status ?? "draft") === "draft"}>draft</option>
          <option value="published" selected={values.status === "published"}>published</option>
        </select>
      </label>
    </div>

    <label class="full">
      <span>摘要</span>
      <textarea name="description" rows="3" required>{values.description ?? ""}</textarea>
    </label>

    <div class="two-col">
      <label>
        <span>SEO 标题</span>
        <input type="text" name="seoTitle" value={values.seoTitle ?? ""} />
      </label>
      <label>
        <span>封面链接</span>
        <input type="text" name="cover" value={values.cover ?? ""} />
      </label>
    </div>

    <label class="full">
      <span>SEO 摘要</span>
      <textarea name="seoDescription" rows="3">{values.seoDescription ?? ""}</textarea>
    </label>

    <label class="full">
      <span>标签</span>
      <input
        type="text"
        name="tags"
        value={joinedTags}
        placeholder="Python 爬虫, 实战, 网络请求"
      />
    </label>

    <label class="checkbox">
      <input
        type="checkbox"
        name="featured"
        value="true"
        checked={values.featured ?? false}
      />
      <span>设为精选文章</span>
    </label>

    <label class="full">
      <span>正文内容（Markdown）</span>
      <textarea name="content" rows="18" required>{values.content ?? ""}</textarea>
    </label>

      <div class="actions">
        <button type="submit">{submitLabel}</button>
        <a href="/admin/posts">返回文章列表</a>
      </div>
    </form>

    <aside class="preview-panel">
      <div class="preview-head">
        <p class="eyebrow">Preview</p>
        <h2>实时预览</h2>
      </div>
      <div class="preview-content prose" set:html={previewHtml || "<p>这里会显示正文预览。</p>"} />
    </aside>
  </div>
</section>

<style>
  .form-card {
    border: 1px solid var(--line);
    border-radius: 28px;
    padding: 1.5rem;
    background: var(--panel);
    box-shadow: var(--shadow);
  }

  h1 {
    margin: 0.25rem 0 0;
    font-size: clamp(2rem, 6vw, 3rem);
    letter-spacing: -0.06em;
  }

  .editor-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
    gap: 1.2rem;
    margin-top: 1.2rem;
  }

  .editor-form {
    display: grid;
    gap: 1rem;
  }

  .two-col {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  label {
    display: grid;
    gap: 0.45rem;
  }

  label span {
    color: var(--muted);
    font-size: 0.95rem;
  }

  input,
  textarea,
  select {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 0.85rem 1rem;
    background: rgba(255, 255, 255, 0.75);
    color: var(--ink);
    font: inherit;
  }

  .checkbox {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .checkbox input {
    width: auto;
  }

  .actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  button {
    border: 0;
    border-radius: 999px;
    padding: 0.88rem 1.15rem;
    background: var(--ink);
    color: var(--panel-strong);
    font: inherit;
    cursor: pointer;
  }

  button:hover {
    background: var(--accent-dark);
  }

  .preview-panel {
    border: 1px solid var(--line);
    border-radius: 22px;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.55);
  }

  .preview-head h2 {
    margin: 0.2rem 0 0.8rem;
    font-size: 1.5rem;
    letter-spacing: -0.04em;
  }

  .preview-content {
    color: var(--ink);
    line-height: 1.75;
  }

  .preview-content :global(h1),
  .preview-content :global(h2),
  .preview-content :global(h3) {
    line-height: 1.2;
    letter-spacing: -0.03em;
  }

  .preview-content :global(pre) {
    white-space: pre-wrap;
  }

  @media (max-width: 860px) {
    .editor-shell {
      grid-template-columns: 1fr;
    }

    .two-col {
      grid-template-columns: 1fr;
    }
  }
</style>
