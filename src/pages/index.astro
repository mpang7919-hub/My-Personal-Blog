---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getLatestPosts } from "../lib/posts";
import { siteConfig } from "../lib/site";

const posts = await getLatestPosts(3);
const rootUrl = Astro.site ? Astro.site.toString() : Astro.url.origin;
const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteConfig.title,
  description: siteConfig.description,
  url: rootUrl,
  inLanguage: "zh-CN",
};
const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: siteConfig.author.name,
  url: rootUrl,
  description: siteConfig.author.shortBio,
};
---

<BaseLayout
  title={siteConfig.title}
  description={siteConfig.description}
  keywords={["Python 爬虫", "JS 逆向", "AI 大模型", "技术博客"]}
  structuredData={[websiteJsonLd, personJsonLd]}
>
  <section class="container hero">
    <div class="hero-copy">
      <p class="eyebrow">{siteConfig.hero.eyebrow}</p>
      <h1 class="page-title">{siteConfig.hero.title}</h1>
      <p class="lede">
        {siteConfig.hero.description}
      </p>
      <div class="actions">
        <a class="button" href={siteConfig.hero.primaryCta.href}>
          {siteConfig.hero.primaryCta.label}
        </a>
        <a class="ghost" href={siteConfig.hero.secondaryCta.href}>
          {siteConfig.hero.secondaryCta.label}
        </a>
      </div>
      <div class="focus-list" aria-label="内容方向">
        {siteConfig.focusAreas.map((item) => <span>{item}</span>)}
      </div>
    </div>

    <aside class="hero-panel">
      <p class="panel-label">Signal</p>
      <div class="signal-card">
        {siteConfig.signalCards.map((item) => (
          <div>
            <span class="signal-key">{item.label}</span>
            <strong>{item.value}</strong>
          </div>
        ))}
      </div>
      <pre><code>{`$ ./observe --target request-chain
[trace] request captured
[trace] signature located
[note ] publish after verification`}</code></pre>
    </aside>
  </section>

  <section class="container page-section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Latest</p>
        <h2>最近更新</h2>
      </div>
      <p>围绕实战问题写，不追求堆砌名词，只保留真正有用的拆解过程。</p>
    </div>
    <div class="grid">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.78fr);
    gap: 1.4rem;
    align-items: stretch;
    padding-block: 4.5rem 2.8rem;
  }

  .hero-copy,
  .hero-panel {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 34px;
    padding: 1.5rem;
    background: var(--panel);
    backdrop-filter: blur(18px);
    box-shadow: var(--shadow);
  }

  .hero-copy::before,
  .hero-panel::before {
    content: "";
    position: absolute;
    inset: 0 auto auto 0;
    width: 10rem;
    height: 10rem;
    background: radial-gradient(circle, rgba(211, 106, 46, 0.16), transparent 70%);
    pointer-events: none;
  }

  .actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2rem;
  }

  .button,
  .ghost {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0.78rem 1.18rem;
    text-decoration: none;
  }

  .button {
    background: var(--ink);
    color: var(--panel-strong);
  }

  .button:hover {
    background: var(--accent-dark);
    color: var(--panel-strong);
    transform: translateY(-1px);
  }

  .ghost {
    border: 1px solid var(--line);
    color: var(--ink);
    background: rgba(255, 255, 255, 0.38);
  }

  .ghost:hover {
    border-color: var(--accent);
  }

  .focus-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.75rem;
  }

  .focus-list span {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.45rem 0.85rem;
    background: rgba(255, 250, 241, 0.72);
    color: var(--muted);
    font-family: "Cascadia Code", Consolas, monospace;
    font-size: 0.88rem;
  }

  .panel-label {
    margin: 0 0 0.7rem;
    color: var(--accent);
    font-family: "Cascadia Code", Consolas, monospace;
    font-size: 0.85rem;
    text-transform: uppercase;
  }

  .signal-card {
    display: grid;
    gap: 0.85rem;
    margin-bottom: 1rem;
  }

  .signal-card div {
    border: 1px solid var(--line);
    border-radius: 22px;
    padding: 0.9rem 1rem;
    background: rgba(255, 252, 247, 0.72);
  }

  .signal-key {
    display: block;
    color: var(--muted);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .signal-card strong {
    display: block;
    margin-top: 0.2rem;
    font-size: 1rem;
    line-height: 1.35;
  }

  .hero-panel pre {
    margin: 0;
  }

  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .section-head h2 {
    margin: 0.2rem 0 0;
    font-size: clamp(2rem, 5vw, 3rem);
    letter-spacing: -0.05em;
  }

  .section-head p:last-child {
    max-width: 420px;
    margin: 0;
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .hero-copy,
    .hero-panel {
      border-radius: 26px;
      padding: 1.2rem;
    }

    .section-head {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
