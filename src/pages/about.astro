---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../lib/site";

const rootUrl = Astro.site ? Astro.site.toString() : Astro.url.origin;
const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: siteConfig.author.name,
  url: rootUrl,
  description: siteConfig.author.shortBio,
};
---

<BaseLayout
  title={`关于${siteConfig.author.name} | ${siteConfig.title}`}
  description={`关于${siteConfig.author.name}，以及这个博客会写什么。`}
  keywords={["鸣", "作者介绍", "Python 爬虫", "JS 逆向", "AI 大模型"]}
  structuredData={personJsonLd}
>
  <section class="container page-section about">
    <p class="eyebrow">About</p>
    <h1 class="page-title">关于{siteConfig.author.name}</h1>
    <p class="lede">
      {siteConfig.author.aboutIntro}
    </p>
    <div class="panel">
      {siteConfig.author.aboutParagraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </section>
</BaseLayout>

<style>
  .about {
    max-width: 820px;
  }

  .panel {
    border: 1px solid var(--line);
    border-radius: 28px;
    padding: 1.5rem;
    background: var(--panel);
    box-shadow: var(--shadow);
  }
</style>
