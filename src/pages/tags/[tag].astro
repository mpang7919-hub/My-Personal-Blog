---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getAllTags, getPublishedPosts } from "../../lib/posts";

export async function getStaticPaths() {
  const tags = await getAllTags();

  return tags.map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const posts = (await getPublishedPosts()).filter((post) =>
  post.data.tags.includes(tag),
);
---

<BaseLayout
  title={`#${tag} | 鸣的技术手记`}
  description={`标签 ${tag} 下的文章。`}
  keywords={[tag, "标签归档", "技术博客"]}
>
  <section class="container page-section tag-page">
    <div class="intro-card">
      <p class="eyebrow">Tag</p>
      <h1 class="page-title">#{tag}</h1>
      <p class="lede">这个标签下目前有 {posts.length} 篇文章。</p>
    </div>
    <div class="grid">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>

<style>
  .tag-page {
    display: grid;
    gap: 1.4rem;
  }

  .intro-card {
    border: 1px solid var(--line);
    border-radius: 32px;
    padding: 1.5rem;
    background: var(--panel);
    box-shadow: var(--shadow);
  }
</style>
